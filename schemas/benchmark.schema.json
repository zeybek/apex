{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Apex skill benchmark run",
  "description": "A recorded with-skill-versus-baseline measurement for one skill on a pinned model.",
  "type": "object",
  "additionalProperties": false,
  "required": ["skill", "client", "model", "date", "samples", "with_skill", "baseline"],
  "properties": {
    "skill": { "type": "string", "minLength": 1 },
    "client": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "samples": { "type": "integer", "minimum": 1 },
    "notes": { "type": "string" },
    "with_skill": { "$ref": "#/definitions/metrics" },
    "baseline": { "$ref": "#/definitions/metrics" }
  },
  "definitions": {
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertion_pass_rate"],
      "properties": {
        "assertion_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "trigger_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "duration_ms": { "type": "number", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
